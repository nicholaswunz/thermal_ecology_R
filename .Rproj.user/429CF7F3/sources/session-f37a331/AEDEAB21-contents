project:
  type: book
  output-dir: _book
  resources: 
    - "*.png"
    - "*.jpeg"
    - "*.jfif"
    - "*.svg"
    
    
book:
  title: "Thermal Ecology in R"
  author: "Nicholas Wu"
  date: "4/17/2026"
  reader-mode: true
  page-navigation: true
  back-to-top-navigation: true
  search: true
  
  page-footer:
    border: true
    right: |
      This book was built with <a href="https://quarto.org/">Quarto</a>. This work is licensed under a [CC-BY-NC-ND 4.0 Int License](https://creativecommons.org/licenses/by-nc-nd/4.0/)

  
  
  chapters:
    - index.qmd
    - intro.qmd
    - summary.qmd
    - references.qmd

bibliography: references.bib

format:
  html:
    mainfont: Roboto
    monofont: Fira Code
    highlight-style: arrow
    monobackgroundcolor: "#F7F7F7"
    include-in-header: _fathom.html
    theme: 
      - theme.css
      - theme.scss
      - lumen
    

execute:
  code-annotations: hover
  number-depth: 3

